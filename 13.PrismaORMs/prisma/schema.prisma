
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int         @id @default(autoincrement())
  email       String      @unique
  password    String 
  age         Int
  city        String
}

model Todo {
  id          Int          @id @default(autoincrement())
  title       String       
  description String
  done        Boolean
  userId      Int
}